{
    "version": "0.2.0", // move to .vscode folder
    "configurations": [
        {
            "name": "Python Debugger: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "--app-dir",
                "src",
                "main:app",
                "--reload"
            ],
            "jinja": true,
            "presentation": {
                "hidden": true
            }
        },
        {
            "name": "Chrome Debug",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:8000/docs",
            "presentation": {
                "hidden": true
            }
        }
    ],
    "compounds": [
        {
            "name": "Debug Run",
            "configurations": [
                "Python Debugger: FastAPI",
                "Chrome Debug"
            ]
        }
    ]
}